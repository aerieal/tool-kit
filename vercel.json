{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "build": {
    "env": {
      "CARGO_PROFILE_RELEASE_LTO": "false"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
